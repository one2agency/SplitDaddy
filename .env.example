# Токен бота від @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Шлях до файлу БД SQLite
DB_PATH=splitdaddy.db

# (Опційно) Telegram ID власника — кому доступна команда /stats.
# Дізнатись свій ID: напиши боту /id. Якщо не задано — /stats бачать адміни групи.
# OWNER_ID=123456789

# (Опційно) ID чату для сповіщень про деплой (бот напише «🚀 задеплоєно <commit>»).
# Дізнатись ID потрібного чату: напиши там боту /id.
# NOTIFY_CHAT_ID=-1001234567890
